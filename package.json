{
  "name": "agent-workflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "bin": {
    "agent-workflow": "dist/src/cli.js"
  },
  "engines": {
    "bun": ">=1.3 <2"
  },
  "scripts": {
    "build": "tsc",
    "test": "bun run build && bun test ./dist/tests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "doctor": "react-doctor",
    "agent-workflow": "bun --no-env-file dist/src/cli.js"
  },
  "dependencies": {
    "@langchain/core": "1.2.3",
    "@langchain/langgraph": "1.4.8",
    "@langchain/langgraph-checkpoint-sqlite": "1.0.3",
    "better-sqlite3": "file:./compat/better-sqlite3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "1.3.14",
    "eslint": "^10.7.0",
    "react-doctor": "^0.8.1",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.64.0"
  },
  "overrides": {
    "better-sqlite3": "file:./compat/better-sqlite3"
  }
}
